{
  "name": "image-colour-contrast-checker",
  "private": true,
  "version": "0.3.1",
  "type": "module",
  "description": "Client-side WCAG colour-contrast auditor for images. Runs OCR + contrast analysis entirely in the browser.",
  "license": "MIT",
  "author": "Tim Dixon",
  "repository": {
    "type": "git",
    "url": "https://github.com/timdixon82/Image-Colour-Contrast-Checker.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host",
    "postinstall": "node scripts/copy-models.mjs",
    "predev": "node scripts/copy-models.mjs",
    "prebuild": "node scripts/copy-models.mjs",
    "lint:html": "htmlhint index.html privacy.html",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:js": "eslint \"src/**/*.js\" \"scripts/**/*.mjs\"",
    "lint": "npm run lint:html && npm run lint:css && npm run lint:js"
  },
  "dependencies": {
    "@gutenye/ocr-browser": "^1.4.8",
    "onnxruntime-web": "^1.26.0",
    "pdfmake": "^0.3.9"
  },
  "devDependencies": {
    "@gutenye/ocr-models": "^1.4.2",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "htmlhint": "^1.5.0",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^8.0.14"
  }
}
